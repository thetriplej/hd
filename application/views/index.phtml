	$(window).ready(function(){
		function fnMove(seq){
		var offset = $("#block-div" + seq).offset();
		var winH = $(window).height();
		$('html, body').animate({scrollTop : (offset.top - winH/2 + 250)}, 400);
		}


		$("#bt_point01").click(function(){
			fnMove(1);
		});
		$("#bt_point02").click(function(){
			fnMove(2);
		});

	});		
</script>


